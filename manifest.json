{
  "manifest_version": 3,
  "name": "BrowserCoreClaw",
  "version": "0.6.0",
  "description": "A configurable browser data collection toolbox.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.xiaohongshu.com/*",
    "https://*.xiaohongshu.com/*",
    "https://weibo.com/*",
    "https://www.weibo.com/*",
    "https://douyin.com/*",
    "https://www.douyin.com/*",
    "https://v.douyin.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "打开 BrowserCoreClaw"
  }
}

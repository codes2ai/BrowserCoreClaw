      "icon": "GO",
      "image": "assets/images/google.svg",
      "features": [
        {
          "id": "google-news",
          "name": "Google 新闻监控",
          "description": "按关键词持续采集 Google 新闻结果，支持循环监控、增量去重和数据导出。",
          "status": "beta",
          "runner": "src/groups/google/google-news/runner.js",
          "entry": "src/groups/google/google-news/index.js",
          "style": "src/groups/google/google-news/styles.css"
        }
      ]
    },
    {
      "id": "weibo",
